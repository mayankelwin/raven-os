{
  "name": "raven-os",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.10.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "web": "turbo run dev --filter @apps/web",
    "mobile": "turbo run dev --filter @apps/mobile",
    "build": "turbo run build",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  }
}
